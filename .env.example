# =============================================================================
# AI Growth Engine – Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Variables marked [REQUIRED IN PRODUCTION] must be set when NODE_ENV=production.
# Variables with defaults shown in (parentheses) are optional in development.
# =============================================================================

# ── App ──────────────────────────────────────────────────────────────────────
# Application runtime environment
NODE_ENV=development                          # development | production | test
PORT=3001                                     # HTTP server port (default: 3001)
API_PREFIX=/api/v1                            # URL prefix for all API routes

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# [REQUIRED IN PRODUCTION] PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/ai_growth_engine_dev
DB_POOL_MIN=2                                 # Minimum pool connections (default: 2)
DB_POOL_MAX=10                                # Maximum pool connections (default: 10)
DB_IDLE_TIMEOUT=30000                         # Idle connection timeout in ms (default: 30000)
DB_SSL=false                                  # Enable SSL for DB connections (default: false)
DB_SSL_ENABLED=false                          # Alias for DB_SSL (default: false)
DB_SSL_CA=                                    # Path to SSL CA certificate file
DB_SSL_KEY=                                   # Path to SSL client key file
DB_SSL_CERT=                                  # Path to SSL client certificate file

# ── Redis ────────────────────────────────────────────────────────────────────
# [REQUIRED IN PRODUCTION] Redis connection URL (must not be localhost in prod)
REDIS_URL=redis://localhost:6379              # Redis connection string (default: redis://localhost:6379)
REDIS_PASSWORD=                               # Redis auth password (optional)
REDIS_DB=0                                    # Redis database index (default: 0)
REDIS_TLS_CA=                                 # Path to TLS CA certificate for Redis

# ── Auth / JWT ───────────────────────────────────────────────────────────────
# [REQUIRED IN PRODUCTION] Must be at least 32 characters
JWT_SECRET=your-jwt-secret-key-at-least-32-characters-long
JWT_EXPIRES_IN=24h                            # Access token expiry (default: 24h)
JWT_REFRESH_EXPIRES_IN=7d                     # Refresh token expiry (default: 7d)
SESSION_MAX_LIFETIME_HOURS=24                 # Maximum session duration in hours (default: 24)

# ── Encryption ───────────────────────────────────────────────────────────────
# [REQUIRED IN PRODUCTION] Must be exactly 32 characters
ENCRYPTION_KEY=your-32-char-encryption-key!!  # AES encryption key for sensitive data

# ── Anthropic / AI ───────────────────────────────────────────────────────────
# Optional – AI features are disabled when not set
ANTHROPIC_API_KEY=                            # Anthropic API key for AI features
ANTHROPIC_OPUS_MODEL=claude-opus-4-20250514   # Opus model identifier
ANTHROPIC_SONNET_MODEL=claude-sonnet-4-20250514  # Sonnet model identifier

# ── Kling AI Video ───────────────────────────────────────────────────────────
KLING_API_KEY=                                # Kling API key for video generation

# ── Password Reset ───────────────────────────────────────────────────────────
PASSWORD_RESET_EXPIRY_MINUTES=60              # Password reset token lifetime (default: 60)

# ── Account Lockout ──────────────────────────────────────────────────────────
LOCKOUT_THRESHOLD=5                           # Failed login attempts before lockout (default: 5)
LOCKOUT_DURATION_MINUTES=15                   # Lockout duration in minutes (default: 15)

# ── Rate Limiting (Global) ───────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000                   # Rate limit window in ms (default: 900000 = 15 min)
RATE_LIMIT_MAX_REQUESTS=100                   # Max requests per window (default: 100)

# ── Rate Limiting (Per-User) ─────────────────────────────────────────────────
USER_RATE_LIMIT_MAX=100                       # Max requests per user per window (default: 100)
USER_RATE_LIMIT_WINDOW_SECONDS=60             # Per-user window in seconds (default: 60)

# ── Job Queue ────────────────────────────────────────────────────────────────
MAX_JOB_RETRIES=3                             # Maximum retry attempts for failed jobs (default: 3)

# ── Server Lifecycle ─────────────────────────────────────────────────────────
SHUTDOWN_TIMEOUT_MS=30000                     # Graceful shutdown timeout in ms (default: 30000)

# ── Clustering ───────────────────────────────────────────────────────────────
CLUSTER_ENABLED=false                         # Enable Node.js cluster mode (default: false)
CLUSTER_WORKERS=0                             # Number of workers; 0 = auto (CPU count) (default: 0)

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info                                # Log level: debug | info | warn | error (default: info)
LOG_FORMAT=json                               # Log format: json | text (default: json)

# ── Database Query Logging ───────────────────────────────────────────────────
SLOW_QUERY_THRESHOLD_MS=100                   # Queries slower than this are logged (default: 100)

# ── APM / Observability ──────────────────────────────────────────────────────
SENTRY_DSN=                                   # Sentry DSN for error tracking (optional)
APM_ENABLED=false                             # Enable APM/Sentry integration (default: false)
METRICS_ENABLED=true                          # Enable Prometheus metrics (default: true)

# ── CORS ─────────────────────────────────────────────────────────────────────
# [REQUIRED IN PRODUCTION] Must not contain localhost
CORS_ORIGIN=                                  # Single CORS origin (optional, overrides CORS_ORIGINS)
CORS_ORIGINS=http://localhost:5173            # Comma-separated allowed origins (default: http://localhost:5173)

# ── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=                             # Google OAuth 2.0 client ID
GOOGLE_CLIENT_SECRET=                         # Google OAuth 2.0 client secret
GOOGLE_CALLBACK_URL=/api/auth/google/callback # OAuth callback path (default: /api/auth/google/callback)

# ── MFA ──────────────────────────────────────────────────────────────────────
MFA_ISSUER=AIGrowthEngine                     # TOTP issuer name shown in authenticator apps (default: AIGrowthEngine)

# ── Bandit / Contextual Bandits ──────────────────────────────────────────────
BANDIT_DECAY_HALF_LIFE_DAYS=30                # Reward decay half-life in days (default: 30)
BANDIT_EXPLORATION_BONUS=0.1                  # UCB exploration bonus factor (default: 0.1)
