# Server
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_growth_engine
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_SSL=false

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Encryption
ENCRYPTION_KEY=change-me-32-char-encryption-key

# Anthropic AI
ANTHROPIC_API_KEY=
ANTHROPIC_OPUS_MODEL=claude-opus-4-20250514
ANTHROPIC_SONNET_MODEL=claude-sonnet-4-20250514

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# MFA
MFA_ISSUER=AIGrowthEngine
