{
  "name": "ai-growth-engine-server",
  "version": "1.0.0",
  "description": "AI International Growth Engine - Backend API Server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:unit": "jest --testPathPattern=tests/unit --forceExit",
    "test:integration": "jest --testPathPattern=tests/integration --forceExit",
    "test:e2e": "jest --testPathPattern=tests/e2e --forceExit",
    "migrate": "tsx src/migrations/run.ts",
    "seed": "tsx src/seeds/seed.ts",
    "lint": "eslint src/"
  },
  "dependencies": {
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.4.0",
    "pg": "^8.13.0",
    "pg-pool": "^3.7.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "zod": "^3.23.8",
    "dotenv": "^16.4.5",
    "winston": "^3.14.2",
    "uuid": "^10.0.0",
    "otplib": "^12.0.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "hpp": "^0.2.3"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "tsx": "^4.19.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/hpp": "^0.2.6",
    "@types/pg": "^8.11.10",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/uuid": "^10.0.0",
    "@types/node": "^22.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "@types/jest": "^29.5.13",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.10.0"
  }
}
