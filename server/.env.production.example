# ── App ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
API_PREFIX=/api/v1

# ── Database (REQUIRED) ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/ai_growth_engine
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_SSL=true

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://host:6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0

# ── Auth / JWT (REQUIRED - min 32 chars) ─────────────────────────────
JWT_SECRET=your-jwt-secret-minimum-32-characters-long
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ── Encryption (REQUIRED - exactly 32 chars) ─────────────────────────
ENCRYPTION_KEY=your-32-character-encryption-key!

# ── Anthropic / AI (Optional - graceful degradation if missing) ──────
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_OPUS_MODEL=claude-opus-4-20250514
ANTHROPIC_SONNET_MODEL=claude-sonnet-4-20250514

# ── Rate Limiting ────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── Logging ──────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json

# ── CORS ─────────────────────────────────────────────────────────────
CORS_ORIGINS=https://your-domain.com

# ── MFA ──────────────────────────────────────────────────────────────
MFA_ISSUER=AIGrowthEngine
